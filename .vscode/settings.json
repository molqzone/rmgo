{
        "clangd.arguments": [
                "--compile-commands-dir=/workspaces/rmgo/rmgo_ws/build",
                "--query-driver=/usr/bin/clang++,/usr/bin/g++,/opt/ros/jazzy/bin/*"
        ],
        "cSpell.words": [
                "bringup",
                "cwise",
                "Eigen",
                "feedforward",
                "initializable",
                "rclcpp",
                "RMCS",
                "rmgo",
                "rviz",
                "supercap",
                "tabchars",
                "Teleop"
        ],
        "cSpell.customDictionaries": {
                "custom-dictionary-workspace": {
                        "name": "custom-dictionary-workspace",
                        "path": "${workspaceFolder:rmgo}/.cspell/custom-dictionary-workspace.txt",
                        "addWords": true,
                        "scope": "workspace"
                }
        }
}
