<?xml version="1.0"?>
<robot name="omni_infantry" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="hardware_plugin" default="rmgo_core/OmniInfantryGzInterface"/>
  <xacro:arg name="command_hardware_plugin" default="rmgo_core/CommandGzInterface"/>
  <xacro:arg name="controllers_file" default="$(find rmgo_description)/config/omni_infantry_controllers.yaml"/>

  <xacro:property name="wheel_distance_x" value="0.31794"/>
  <xacro:property name="wheel_distance_y" value="0.31794"/>
  <xacro:property name="gimbal_center_height" value="0.32059"/>

  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <material name="black">
    <color rgba="0.02 0.02 0.02 1"/>
  </material>

  <xacro:macro name="box_inertial" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <inertia
        ixx="${mass * (y * y + z * z) / 12.0}"
        ixy="0.0"
        ixz="0.0"
        iyy="${mass * (x * x + z * z) / 12.0}"
        iyz="0.0"
        izz="${mass * (x * x + y * y) / 12.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="x_cylinder_inertial" params="mass radius length">
    <inertial>
      <mass value="${mass}"/>
      <inertia
        ixx="${0.5 * mass * radius * radius}"
        ixy="0.0"
        ixz="0.0"
        iyy="${mass * (3.0 * radius * radius + length * length) / 12.0}"
        iyz="0.0"
        izz="${mass * (3.0 * radius * radius + length * length) / 12.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="tiny_inertial" params="mass">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${mass * 1e-6}" ixy="0.0" ixz="0.0" iyy="${mass * 1e-6}" iyz="0.0" izz="${mass * 1e-6}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="box_collision" params="x y z">
    <collision>
      <geometry>
        <box size="${x} ${y} ${z}"/>
      </geometry>
    </collision>
  </xacro:macro>

  <xacro:macro name="stl_visual" params="filename">
    <visual>
      <geometry>
        <mesh filename="package://rmgo_description/meshes/visual/${filename}"/>
      </geometry>
      <material name="white"/>
    </visual>
  </xacro:macro>

  <link name="base_link">
    <xacro:box_inertial mass="10.0" x="0.45" y="0.45" z="0.12"/>
    <xacro:stl_visual filename="base_link.stl"/>
    <xacro:box_collision x="0.45" y="0.45" z="0.12"/>
  </link>

  <xacro:macro name="generate_wheel" params="name rpy xyz">
    <link name="${name}_wheel_link">
      <xacro:x_cylinder_inertial mass="0.5" radius="0.07" length="0.05"/>
      <xacro:stl_visual filename="wheel_link.stl"/>
      <collision>
        <origin rpy="0 ${pi/2} 0"/>
        <geometry>
          <cylinder radius="0.07" length="0.05"/>
        </geometry>
      </collision>
    </link>
    <joint name="${name}_wheel_joint" type="continuous">
      <axis xyz="1 0 0"/>
      <limit effort="20.0" velocity="40.0"/>
      <parent link="base_link"/>
      <child link="${name}_wheel_link"/>
      <origin rpy="${rpy}" xyz="${xyz}"/>
    </joint>
  </xacro:macro>

  <xacro:generate_wheel
    name="left_front"
    rpy="0 0 ${pi/4}"
    xyz="${wheel_distance_x/2} ${wheel_distance_y/2} 0"/>
  <xacro:generate_wheel
    name="left_back"
    rpy="0 0 ${3*pi/4}"
    xyz="-${wheel_distance_x/2} ${wheel_distance_y/2} 0"/>
  <xacro:generate_wheel
    name="right_back"
    rpy="0 0 -${3*pi/4}"
    xyz="-${wheel_distance_x/2} -${wheel_distance_y/2} 0"/>
  <xacro:generate_wheel
    name="right_front"
    rpy="0 0 -${pi/4}"
    xyz="${wheel_distance_x/2} -${wheel_distance_y/2} 0"/>

  <link name="yaw_link">
    <xacro:box_inertial mass="2.0" x="0.18" y="0.18" z="0.12"/>
    <xacro:stl_visual filename="yaw_link.stl"/>
    <xacro:box_collision x="0.18" y="0.18" z="0.12"/>
  </link>
  <joint name="yaw_joint" type="continuous">
    <axis xyz="0 0 1"/>
    <limit effort="10.0" velocity="6.0"/>
    <parent link="base_link"/>
    <child link="yaw_link"/>
    <origin xyz="0 0 ${gimbal_center_height}"/>
  </joint>

  <link name="pitch_link">
    <xacro:box_inertial mass="1.0" x="0.20" y="0.12" z="0.12"/>
    <xacro:stl_visual filename="pitch_link.stl"/>
    <xacro:box_collision x="0.20" y="0.12" z="0.12"/>
  </link>
  <joint name="pitch_joint" type="continuous">
    <axis xyz="0 1 0"/>
    <limit effort="10.0" velocity="6.0"/>
    <parent link="yaw_link"/>
    <child link="pitch_link"/>
  </joint>

  <link name="left_friction_link">
    <xacro:x_cylinder_inertial mass="0.08" radius="0.025" length="0.025"/>
    <visual>
      <origin rpy="0 ${pi/2} 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.025"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="left_friction_joint" type="continuous">
    <axis xyz="1 0 0"/>
    <limit effort="2.0" velocity="800.0"/>
    <parent link="pitch_link"/>
    <child link="left_friction_link"/>
    <origin xyz="0.075 0.04 0"/>
  </joint>

  <link name="right_friction_link">
    <xacro:x_cylinder_inertial mass="0.08" radius="0.025" length="0.025"/>
    <visual>
      <origin rpy="0 ${pi/2} 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.025"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="right_friction_joint" type="continuous">
    <axis xyz="1 0 0"/>
    <limit effort="2.0" velocity="800.0"/>
    <parent link="pitch_link"/>
    <child link="right_friction_link"/>
    <origin xyz="0.075 -0.04 0"/>
  </joint>

  <link name="bullet_feeder_link">
    <xacro:x_cylinder_inertial mass="0.12" radius="0.03" length="0.025"/>
    <visual>
      <origin rpy="0 ${pi/2} 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.025"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>
  <joint name="bullet_feeder_joint" type="continuous">
    <axis xyz="1 0 0"/>
    <limit effort="4.0" velocity="60.0"/>
    <parent link="pitch_link"/>
    <child link="bullet_feeder_link"/>
    <origin xyz="-0.025 0 -0.035"/>
  </joint>

  <link name="imu_link">
    <xacro:tiny_inertial mass="0.01"/>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="pitch_link"/>
    <child link="imu_link"/>
    <origin rpy="0 0 ${pi/2}" xyz="0 0 0"/>
  </joint>

  <link name="muzzle_link">
    <xacro:tiny_inertial mass="0.01"/>
  </link>
  <joint name="muzzle_joint" type="fixed">
    <parent link="pitch_link"/>
    <child link="muzzle_link"/>
    <origin xyz="0.059 0 0"/>
  </joint>

  <link name="camera_link">
    <xacro:tiny_inertial mass="0.05"/>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="pitch_link"/>
    <child link="camera_link"/>
    <origin xyz="0.06603 0 0.082"/>
  </joint>

  <ros2_control name="OmniInfantry" type="system">
    <hardware>
      <plugin>$(arg hardware_plugin)</plugin>
    </hardware>

    <joint name="left_front_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="left_back_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_back_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_front_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="yaw_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="pitch_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="left_friction_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_friction_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="bullet_feeder_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <ros2_control name="CommandGz" type="system">
    <hardware>
      <plugin>$(arg command_hardware_plugin)</plugin>
    </hardware>

    <gpio name="command/chassis/linear/x">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
    </gpio>
    <gpio name="command/chassis/linear/y">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
    </gpio>
    <gpio name="command/chassis/angular/z">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
    </gpio>
    <gpio name="command/chassis">
      <command_interface name="mode"/>
      <state_interface name="mode"/>
    </gpio>
    <gpio name="command/gimbal/yaw">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
    </gpio>
    <gpio name="command/gimbal/pitch">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
    </gpio>
    <gpio name="command/gimbal">
      <command_interface name="enabled"/>
      <state_interface name="enabled"/>
    </gpio>
    <gpio name="command/shooter">
      <command_interface name="mode"/>
      <command_interface name="sequence"/>
      <state_interface name="mode"/>
      <state_interface name="sequence"/>
    </gpio>
  </ros2_control>

  <gazebo>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(arg controllers_file)</parameters>
    </plugin>
  </gazebo>
</robot>
