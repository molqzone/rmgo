<?xml version="1.0"?>
<robot name="omni_infantry" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:property name="wheel_distance_x" value="0.31794"/>
  <xacro:property name="wheel_distance_y" value="0.31794"/>
  <xacro:property name="gimbal_center_height" value="0.32059"/>
  <xacro:property name="controllers_file" value="$(find rmgo_description)/config/omni_infantry_controllers.yaml"/>

  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <xacro:macro name="stl_visual" params="filename">
    <visual>
      <geometry>
        <mesh filename="package://rmgo_description/meshes/visual/${filename}"/>
      </geometry>
      <material name="white"/>
    </visual>
  </xacro:macro>

  <link name="base_link">
    <xacro:stl_visual filename="base_link.stl"/>
  </link>

  <xacro:macro name="generate_wheel" params="name rpy xyz">
    <link name="${name}_wheel_link">
      <xacro:stl_visual filename="wheel_link.stl"/>
    </link>
    <joint name="${name}_wheel_joint" type="continuous">
      <axis xyz="1 0 0"/>
      <limit effort="20.0" velocity="40.0"/>
      <parent link="base_link"/>
      <child link="${name}_wheel_link"/>
      <origin rpy="${rpy}" xyz="${xyz}"/>
    </joint>
  </xacro:macro>

  <xacro:generate_wheel
    name="left_front"
    rpy="0 0 ${pi/4}"
    xyz="${wheel_distance_x/2} ${wheel_distance_y/2} 0"/>
  <xacro:generate_wheel
    name="left_back"
    rpy="0 0 ${3*pi/4}"
    xyz="-${wheel_distance_x/2} ${wheel_distance_y/2} 0"/>
  <xacro:generate_wheel
    name="right_back"
    rpy="0 0 -${3*pi/4}"
    xyz="-${wheel_distance_x/2} -${wheel_distance_y/2} 0"/>
  <xacro:generate_wheel
    name="right_front"
    rpy="0 0 -${pi/4}"
    xyz="${wheel_distance_x/2} -${wheel_distance_y/2} 0"/>

  <link name="yaw_link">
    <xacro:stl_visual filename="yaw_link.stl"/>
  </link>
  <joint name="yaw_joint" type="continuous">
    <axis xyz="0 0 1"/>
    <limit effort="10.0" velocity="6.0"/>
    <parent link="base_link"/>
    <child link="yaw_link"/>
    <origin xyz="0 0 ${gimbal_center_height}"/>
  </joint>

  <link name="pitch_link">
    <xacro:stl_visual filename="pitch_link.stl"/>
  </link>
  <joint name="pitch_joint" type="continuous">
    <axis xyz="0 1 0"/>
    <limit effort="10.0" velocity="6.0"/>
    <parent link="yaw_link"/>
    <child link="pitch_link"/>
  </joint>

  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="pitch_link"/>
    <child link="imu_link"/>
    <origin rpy="0 0 ${pi/2}" xyz="0 0 0"/>
  </joint>

  <link name="muzzle_link"/>
  <joint name="muzzle_joint" type="fixed">
    <parent link="pitch_link"/>
    <child link="muzzle_link"/>
    <origin xyz="0.059 0 0"/>
  </joint>

  <link name="camera_link"/>
  <joint name="camera_joint" type="fixed">
    <parent link="pitch_link"/>
    <child link="camera_link"/>
    <origin xyz="0.06603 0 0.082"/>
  </joint>

  <ros2_control name="OmniInfantryGz" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="left_front_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="left_back_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_back_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_front_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="yaw_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="pitch_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>${controllers_file}</parameters>
    </plugin>
  </gazebo>
</robot>
